package yoshuawuyts:acp@2.0.3;

/// World implemented by an ACP agent packaged as a Wasm component.
///
/// The component exports the [`agent`] interface so a host editor can drive
/// it, and imports the [`client`] interface so it can stream updates and
/// call into client capabilities (fs, terminal, permission prompts).
world agent {
    export agent;
    import client;
}

/// World implemented by a host (e.g. an editor like Zed) that drives ACP
/// agent components.
///
/// The host imports the [`agent`] interface to call into a loaded agent
/// component, and exports the [`client`] interface so the agent can call
/// back into it.
world client {
    import agent;
    export client;
}
