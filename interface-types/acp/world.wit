package yoshuawuyts:acp@2.0.3;

/// This interface defines all types shared by both client and server implementations
interface types {
  enum agent-client-protocol {
    /// A message (request, response, or notification) with `"jsonrpc": "2.0"` specified as
    /// [required by JSON-RPC 2.0 Specification][1].
    ///
    /// [1]: https://www.jsonrpc.org/specification#compatibility
    case-zero,
    /// A message (request, response, or notification) with `"jsonrpc": "2.0"` specified as
    /// [required by JSON-RPC 2.0 Specification][1].
    ///
    /// [1]: https://www.jsonrpc.org/specification#compatibility
    case-one,
  }
  /// Capabilities supported by the agent.
  ///
  /// Advertised during initialization to inform the client about
  /// available features and content types.
  ///
  /// See protocol docs: [Agent Capabilities](https://agentclientprotocol.com/protocol/initialization#agent-capabilities)
  record agent-capabilities {
    /// The _meta property is reserved by ACP to allow clients and agents to attach additional
    /// metadata to their interactions. Implementations MUST NOT make assumptions about values at
    /// these keys.
    ///
    /// See protocol docs: [Extensibility](https://agentclientprotocol.com/protocol/extensibility)
    meta: option<list<tuple<string, string>>>,
    /// Whether the agent supports `session/load`.
    load-session: bool,
  }
  record agent-notification {
    method: string,
  }
  record agent-request {
    method: string,
  }
  enum agent-response {
    case-zero,
    case-one,
  }
  /// Optional annotations for the client. The client can use annotations to inform how objects are used or displayed
  record annotations {
    /// The _meta property is reserved by ACP to allow clients and agents to attach additional
    /// metadata to their interactions. Implementations MUST NOT make assumptions about values at
    /// these keys.
    ///
    /// See protocol docs: [Extensibility](https://agentclientprotocol.com/protocol/extensibility)
    meta: option<list<tuple<string, string>>>,
    audience: option<list<role>>,
    last-modified: option<string>,
    priority: option<f64>,
  }
  /// Audio provided to or from an LLM.
  record audio-content {
    /// The _meta property is reserved by ACP to allow clients and agents to attach additional
    /// metadata to their interactions. Implementations MUST NOT make assumptions about values at
    /// these keys.
    ///
    /// See protocol docs: [Extensibility](https://agentclientprotocol.com/protocol/extensibility)
    meta: option<list<tuple<string, string>>>,
    data: string,
    mime-type: string,
  }
  /// Describes an available authentication method.
  record auth-method {
    /// The _meta property is reserved by ACP to allow clients and agents to attach additional
    /// metadata to their interactions. Implementations MUST NOT make assumptions about values at
    /// these keys.
    ///
    /// See protocol docs: [Extensibility](https://agentclientprotocol.com/protocol/extensibility)
    meta: option<list<tuple<string, string>>>,
    /// Optional description providing more details about this authentication method.
    description: option<string>,
    /// Unique identifier for this authentication method.
    id: string,
    /// Human-readable name of the authentication method.
    name: string,
  }
  /// Request parameters for the authenticate method.
  ///
  /// Specifies which authentication method to use.
  record authenticate-request {
    /// The _meta property is reserved by ACP to allow clients and agents to attach additional
    /// metadata to their interactions. Implementations MUST NOT make assumptions about values at
    /// these keys.
    ///
    /// See protocol docs: [Extensibility](https://agentclientprotocol.com/protocol/extensibility)
    meta: option<list<tuple<string, string>>>,
    /// The ID of the authentication method to use.
    /// Must be one of the methods advertised in the initialize response.
    method-id: string,
  }
  /// Response to the `authenticate` method.
  record authenticate-response {
    /// The _meta property is reserved by ACP to allow clients and agents to attach additional
    /// metadata to their interactions. Implementations MUST NOT make assumptions about values at
    /// these keys.
    ///
    /// See protocol docs: [Extensibility](https://agentclientprotocol.com/protocol/extensibility)
    meta: option<list<tuple<string, string>>>,
  }
  /// Information about a command.
  record available-command {
    /// The _meta property is reserved by ACP to allow clients and agents to attach additional
    /// metadata to their interactions. Implementations MUST NOT make assumptions about values at
    /// these keys.
    ///
    /// See protocol docs: [Extensibility](https://agentclientprotocol.com/protocol/extensibility)
    meta: option<list<tuple<string, string>>>,
    /// Human-readable description of what the command does.
    description: string,
    /// Command name (e.g., `create_plan`, `research_codebase`).
    name: string,
  }
  /// The input specification for a command.
  enum available-command-input {
    /// All text that was typed after the command name is provided as input.
    case-zero,
  }
  /// Available commands are ready or have changed
  record available-commands-update {
    /// The _meta property is reserved by ACP to allow clients and agents to attach additional
    /// metadata to their interactions. Implementations MUST NOT make assumptions about values at
    /// these keys.
    ///
    /// See protocol docs: [Extensibility](https://agentclientprotocol.com/protocol/extensibility)
    meta: option<list<tuple<string, string>>>,
  }
  /// Binary resource contents.
  record blob-resource-contents {
    /// The _meta property is reserved by ACP to allow clients and agents to attach additional
    /// metadata to their interactions. Implementations MUST NOT make assumptions about values at
    /// these keys.
    ///
    /// See protocol docs: [Extensibility](https://agentclientprotocol.com/protocol/extensibility)
    meta: option<list<tuple<string, string>>>,
    blob: string,
    mime-type: option<string>,
    uri: string,
  }
  /// Notification to cancel ongoing operations for a session.
  ///
  /// See protocol docs: [Cancellation](https://agentclientprotocol.com/protocol/prompt-turn#cancellation)
  record cancel-notification {
    /// The _meta property is reserved by ACP to allow clients and agents to attach additional
    /// metadata to their interactions. Implementations MUST NOT make assumptions about values at
    /// these keys.
    ///
    /// See protocol docs: [Extensibility](https://agentclientprotocol.com/protocol/extensibility)
    meta: option<list<tuple<string, string>>>,
  }
  /// Capabilities supported by the client.
  ///
  /// Advertised during initialization to inform the agent about
  /// available features and methods.
  ///
  /// See protocol docs: [Client Capabilities](https://agentclientprotocol.com/protocol/initialization#client-capabilities)
  record client-capabilities {
    /// The _meta property is reserved by ACP to allow clients and agents to attach additional
    /// metadata to their interactions. Implementations MUST NOT make assumptions about values at
    /// these keys.
    ///
    /// See protocol docs: [Extensibility](https://agentclientprotocol.com/protocol/extensibility)
    meta: option<list<tuple<string, string>>>,
    /// Whether the Client support all `terminal/*` methods.
    terminal: bool,
  }
  record client-notification {
    method: string,
  }
  record client-request {
    method: string,
  }
  enum client-response {
    case-zero,
    case-one,
  }
  /// Standard content block (text, images, resources).
  record content {
    /// The _meta property is reserved by ACP to allow clients and agents to attach additional
    /// metadata to their interactions. Implementations MUST NOT make assumptions about values at
    /// these keys.
    ///
    /// See protocol docs: [Extensibility](https://agentclientprotocol.com/protocol/extensibility)
    meta: option<list<tuple<string, string>>>,
  }
  /// Content blocks represent displayable information in the Agent Client Protocol.
  ///
  /// They provide a structured way to handle various types of user-facing content—whether
  /// it's text from language models, images for analysis, or embedded resources for context.
  ///
  /// Content blocks appear in:
  /// - User prompts sent via `session/prompt`
  /// - Language model output streamed through `session/update` notifications
  /// - Progress updates and results from tool calls
  ///
  /// This structure is compatible with the Model Context Protocol (MCP), enabling
  /// agents to seamlessly forward content from MCP tool outputs without transformation.
  ///
  /// See protocol docs: [Content](https://agentclientprotocol.com/protocol/content)
  enum content-block {
    /// Text content. May be plain text or formatted with Markdown.
    ///
    /// All agents MUST support text content blocks in prompts.
    /// Clients SHOULD render this text as Markdown.
    case-zero,
    /// Images for visual context or analysis.
    ///
    /// Requires the `image` prompt capability when included in prompts.
    case-one,
    /// Audio data for transcription or analysis.
    ///
    /// Requires the `audio` prompt capability when included in prompts.
    case-two,
    /// References to resources that the agent can access.
    ///
    /// All agents MUST support resource links in prompts.
    case-three,
    /// Complete resource contents embedded directly in the message.
    ///
    /// Preferred for including context as it avoids extra round-trips.
    ///
    /// Requires the `embeddedContext` prompt capability when included in prompts.
    case-four,
  }
  /// A streamed item of content
  record content-chunk {
    /// The _meta property is reserved by ACP to allow clients and agents to attach additional
    /// metadata to their interactions. Implementations MUST NOT make assumptions about values at
    /// these keys.
    ///
    /// See protocol docs: [Extensibility](https://agentclientprotocol.com/protocol/extensibility)
    meta: option<list<tuple<string, string>>>,
  }
  /// Request to create a new terminal and execute a command.
  record create-terminal-request {
    /// The _meta property is reserved by ACP to allow clients and agents to attach additional
    /// metadata to their interactions. Implementations MUST NOT make assumptions about values at
    /// these keys.
    ///
    /// See protocol docs: [Extensibility](https://agentclientprotocol.com/protocol/extensibility)
    meta: option<list<tuple<string, string>>>,
    /// Array of command arguments.
    args: string,
    /// The command to execute.
    command: string,
    /// Working directory for the command (absolute path).
    cwd: option<string>,
    /// Maximum number of output bytes to retain.
    ///
    /// When the limit is exceeded, the Client truncates from the beginning of the output
    /// to stay within the limit.
    ///
    /// The Client MUST ensure truncation happens at a character boundary to maintain valid
    /// string output, even if this means the retained output is slightly less than the
    /// specified limit.
    output-byte-limit: option<s64>,
  }
  /// Response containing the ID of the created terminal.
  record create-terminal-response {
    /// The _meta property is reserved by ACP to allow clients and agents to attach additional
    /// metadata to their interactions. Implementations MUST NOT make assumptions about values at
    /// these keys.
    ///
    /// See protocol docs: [Extensibility](https://agentclientprotocol.com/protocol/extensibility)
    meta: option<list<tuple<string, string>>>,
    /// The unique identifier for the created terminal.
    terminal-id: string,
  }
  /// The current mode of the session has changed
  ///
  /// See protocol docs: [Session Modes](https://agentclientprotocol.com/protocol/session-modes)
  record current-mode-update {
    /// The _meta property is reserved by ACP to allow clients and agents to attach additional
    /// metadata to their interactions. Implementations MUST NOT make assumptions about values at
    /// these keys.
    ///
    /// See protocol docs: [Extensibility](https://agentclientprotocol.com/protocol/extensibility)
    meta: option<list<tuple<string, string>>>,
  }
  /// A diff representing file modifications.
  ///
  /// Shows changes to files in a format suitable for display in the client UI.
  ///
  /// See protocol docs: [Content](https://agentclientprotocol.com/protocol/tool-calls#content)
  record diff {
    /// The _meta property is reserved by ACP to allow clients and agents to attach additional
    /// metadata to their interactions. Implementations MUST NOT make assumptions about values at
    /// these keys.
    ///
    /// See protocol docs: [Extensibility](https://agentclientprotocol.com/protocol/extensibility)
    meta: option<list<tuple<string, string>>>,
    /// The new content after modification.
    new-text: string,
    /// The original content (None for new files).
    old-text: option<string>,
    /// The file path being modified.
    path: string,
  }
  /// The contents of a resource, embedded into a prompt or tool call result.
  record embedded-resource {
    /// The _meta property is reserved by ACP to allow clients and agents to attach additional
    /// metadata to their interactions. Implementations MUST NOT make assumptions about values at
    /// these keys.
    ///
    /// See protocol docs: [Extensibility](https://agentclientprotocol.com/protocol/extensibility)
    meta: option<list<tuple<string, string>>>,
  }
  /// Resource content that can be embedded in a message.
  enum embedded-resource-resource {
    case-zero,
    case-one,
  }
  /// An environment variable to set when launching an MCP server.
  record env-variable {
    /// The _meta property is reserved by ACP to allow clients and agents to attach additional
    /// metadata to their interactions. Implementations MUST NOT make assumptions about values at
    /// these keys.
    ///
    /// See protocol docs: [Extensibility](https://agentclientprotocol.com/protocol/extensibility)
    meta: option<list<tuple<string, string>>>,
    /// The name of the environment variable.
    name: string,
    /// The value to set for the environment variable.
    value: string,
  }
  /// JSON-RPC error object.
  ///
  /// Represents an error that occurred during method execution, following the
  /// JSON-RPC 2.0 error object specification with optional additional data.
  ///
  /// See protocol docs: [JSON-RPC Error Object](https://www.jsonrpc.org/specification#error_object)
  record error {
    /// A string providing a short description of the error.
    /// The message should be limited to a concise single sentence.
    message: string,
  }
  /// Predefined error codes for common JSON-RPC and ACP-specific errors.
  ///
  /// These codes follow the JSON-RPC 2.0 specification for standard errors
  /// and use the reserved range (-32000 to -32099) for protocol-specific errors.
  variant error-code {
    /// **Parse error**: Invalid JSON was received by the server.
    /// An error occurred on the server while parsing the JSON text.
    case-zero,
    /// **Invalid request**: The JSON sent is not a valid Request object.
    case-one,
    /// **Method not found**: The method does not exist or is not available.
    case-two,
    /// **Invalid params**: Invalid method parameter(s).
    case-three,
    /// **Internal error**: Internal JSON-RPC error.
    /// Reserved for implementation-defined server errors.
    case-four,
    /// **Authentication required**: Authentication is required before this operation can be performed.
    case-five,
    /// **Resource not found**: A given resource, such as a file, was not found.
    case-six,
    /// Other undefined error code.
    case-seven(s32),
  }
  /// Filesystem capabilities supported by the client.
  /// File system capabilities that a client may support.
  ///
  /// See protocol docs: [FileSystem](https://agentclientprotocol.com/protocol/initialization#filesystem)
  record file-system-capability {
    /// The _meta property is reserved by ACP to allow clients and agents to attach additional
    /// metadata to their interactions. Implementations MUST NOT make assumptions about values at
    /// these keys.
    ///
    /// See protocol docs: [Extensibility](https://agentclientprotocol.com/protocol/extensibility)
    meta: option<list<tuple<string, string>>>,
    /// Whether the Client supports `fs/read_text_file` requests.
    read-text-file: bool,
    /// Whether the Client supports `fs/write_text_file` requests.
    write-text-file: bool,
  }
  /// An HTTP header to set when making requests to the MCP server.
  record http-header {
    /// The _meta property is reserved by ACP to allow clients and agents to attach additional
    /// metadata to their interactions. Implementations MUST NOT make assumptions about values at
    /// these keys.
    ///
    /// See protocol docs: [Extensibility](https://agentclientprotocol.com/protocol/extensibility)
    meta: option<list<tuple<string, string>>>,
    /// The name of the HTTP header.
    name: string,
    /// The value to set for the HTTP header.
    value: string,
  }
  /// An image provided to or from an LLM.
  record image-content {
    /// The _meta property is reserved by ACP to allow clients and agents to attach additional
    /// metadata to their interactions. Implementations MUST NOT make assumptions about values at
    /// these keys.
    ///
    /// See protocol docs: [Extensibility](https://agentclientprotocol.com/protocol/extensibility)
    meta: option<list<tuple<string, string>>>,
    data: string,
    mime-type: string,
    uri: option<string>,
  }
  /// Metadata about the implementation of the client or agent.
  /// Describes the name and version of an MCP implementation, with an optional
  /// title for UI representation.
  record implementation {
    /// The _meta property is reserved by ACP to allow clients and agents to attach additional
    /// metadata to their interactions. Implementations MUST NOT make assumptions about values at
    /// these keys.
    ///
    /// See protocol docs: [Extensibility](https://agentclientprotocol.com/protocol/extensibility)
    meta: option<list<tuple<string, string>>>,
    /// Intended for programmatic or logical use, but can be used as a display
    /// name fallback if title isn’t present.
    name: string,
    /// Intended for UI and end-user contexts — optimized to be human-readable
    /// and easily understood.
    ///
    /// If not provided, the name should be used for display.
    title: option<string>,
    /// Version of the implementation. Can be displayed to the user or used
    /// for debugging or metrics purposes. (e.g. "1.0.0").
    version: string,
  }
  /// Request parameters for the initialize method.
  ///
  /// Sent by the client to establish connection and negotiate capabilities.
  ///
  /// See protocol docs: [Initialization](https://agentclientprotocol.com/protocol/initialization)
  record initialize-request {
    /// The _meta property is reserved by ACP to allow clients and agents to attach additional
    /// metadata to their interactions. Implementations MUST NOT make assumptions about values at
    /// these keys.
    ///
    /// See protocol docs: [Extensibility](https://agentclientprotocol.com/protocol/extensibility)
    meta: option<list<tuple<string, string>>>,
  }
  /// Response to the `initialize` method.
  ///
  /// Contains the negotiated protocol version and agent capabilities.
  ///
  /// See protocol docs: [Initialization](https://agentclientprotocol.com/protocol/initialization)
  record initialize-response {
    /// The _meta property is reserved by ACP to allow clients and agents to attach additional
    /// metadata to their interactions. Implementations MUST NOT make assumptions about values at
    /// these keys.
    ///
    /// See protocol docs: [Extensibility](https://agentclientprotocol.com/protocol/extensibility)
    meta: option<list<tuple<string, string>>>,
  }
  /// Request to kill a terminal command without releasing the terminal.
  record kill-terminal-command-request {
    /// The _meta property is reserved by ACP to allow clients and agents to attach additional
    /// metadata to their interactions. Implementations MUST NOT make assumptions about values at
    /// these keys.
    ///
    /// See protocol docs: [Extensibility](https://agentclientprotocol.com/protocol/extensibility)
    meta: option<list<tuple<string, string>>>,
    /// The ID of the terminal to kill.
    terminal-id: string,
  }
  /// Response to terminal/kill command method
  record kill-terminal-command-response {
    /// The _meta property is reserved by ACP to allow clients and agents to attach additional
    /// metadata to their interactions. Implementations MUST NOT make assumptions about values at
    /// these keys.
    ///
    /// See protocol docs: [Extensibility](https://agentclientprotocol.com/protocol/extensibility)
    meta: option<list<tuple<string, string>>>,
  }
  /// Request parameters for loading an existing session.
  ///
  /// Only available if the Agent supports the `loadSession` capability.
  ///
  /// See protocol docs: [Loading Sessions](https://agentclientprotocol.com/protocol/session-setup#loading-sessions)
  record load-session-request {
    /// The _meta property is reserved by ACP to allow clients and agents to attach additional
    /// metadata to their interactions. Implementations MUST NOT make assumptions about values at
    /// these keys.
    ///
    /// See protocol docs: [Extensibility](https://agentclientprotocol.com/protocol/extensibility)
    meta: option<list<tuple<string, string>>>,
    /// The working directory for this session.
    cwd: string,
  }
  /// Response from loading an existing session.
  record load-session-response {
    /// The _meta property is reserved by ACP to allow clients and agents to attach additional
    /// metadata to their interactions. Implementations MUST NOT make assumptions about values at
    /// these keys.
    ///
    /// See protocol docs: [Extensibility](https://agentclientprotocol.com/protocol/extensibility)
    meta: option<list<tuple<string, string>>>,
  }
  /// MCP capabilities supported by the agent
  record mcp-capabilities {
    /// The _meta property is reserved by ACP to allow clients and agents to attach additional
    /// metadata to their interactions. Implementations MUST NOT make assumptions about values at
    /// these keys.
    ///
    /// See protocol docs: [Extensibility](https://agentclientprotocol.com/protocol/extensibility)
    meta: option<list<tuple<string, string>>>,
    /// Agent supports [`McpServer::Http`].
    http: bool,
    /// Agent supports [`McpServer::Sse`].
    sse: bool,
  }
  /// Configuration for connecting to an MCP (Model Context Protocol) server.
  ///
  /// MCP servers provide tools and context that the agent can use when
  /// processing prompts.
  ///
  /// See protocol docs: [MCP Servers](https://agentclientprotocol.com/protocol/session-setup#mcp-servers)
  enum mcp-server {
    /// HTTP transport configuration
    ///
    /// Only available when the Agent capabilities indicate `mcp_capabilities.http` is `true`.
    case-zero,
    /// SSE transport configuration
    ///
    /// Only available when the Agent capabilities indicate `mcp_capabilities.sse` is `true`.
    case-one,
    /// Stdio transport configuration
    ///
    /// All Agents MUST support this transport.
    case-two,
  }
  /// HTTP transport configuration for MCP.
  record mcp-server-http {
    /// The _meta property is reserved by ACP to allow clients and agents to attach additional
    /// metadata to their interactions. Implementations MUST NOT make assumptions about values at
    /// these keys.
    ///
    /// See protocol docs: [Extensibility](https://agentclientprotocol.com/protocol/extensibility)
    meta: option<list<tuple<string, string>>>,
    /// Human-readable name identifying this MCP server.
    name: string,
    /// URL to the MCP server.
    url: string,
  }
  /// SSE transport configuration for MCP.
  record mcp-server-sse {
    /// The _meta property is reserved by ACP to allow clients and agents to attach additional
    /// metadata to their interactions. Implementations MUST NOT make assumptions about values at
    /// these keys.
    ///
    /// See protocol docs: [Extensibility](https://agentclientprotocol.com/protocol/extensibility)
    meta: option<list<tuple<string, string>>>,
    /// Human-readable name identifying this MCP server.
    name: string,
    /// URL to the MCP server.
    url: string,
  }
  /// Stdio transport configuration for MCP.
  record mcp-server-stdio {
    /// The _meta property is reserved by ACP to allow clients and agents to attach additional
    /// metadata to their interactions. Implementations MUST NOT make assumptions about values at
    /// these keys.
    ///
    /// See protocol docs: [Extensibility](https://agentclientprotocol.com/protocol/extensibility)
    meta: option<list<tuple<string, string>>>,
    /// Command-line arguments to pass to the MCP server.
    args: string,
    /// Path to the MCP server executable.
    command: string,
    /// Human-readable name identifying this MCP server.
    name: string,
  }
  /// Request parameters for creating a new session.
  ///
  /// See protocol docs: [Creating a Session](https://agentclientprotocol.com/protocol/session-setup#creating-a-session)
  record new-session-request {
    /// The _meta property is reserved by ACP to allow clients and agents to attach additional
    /// metadata to their interactions. Implementations MUST NOT make assumptions about values at
    /// these keys.
    ///
    /// See protocol docs: [Extensibility](https://agentclientprotocol.com/protocol/extensibility)
    meta: option<list<tuple<string, string>>>,
    /// The working directory for this session. Must be an absolute path.
    cwd: string,
  }
  /// Response from creating a new session.
  ///
  /// See protocol docs: [Creating a Session](https://agentclientprotocol.com/protocol/session-setup#creating-a-session)
  record new-session-response {
    /// The _meta property is reserved by ACP to allow clients and agents to attach additional
    /// metadata to their interactions. Implementations MUST NOT make assumptions about values at
    /// these keys.
    ///
    /// See protocol docs: [Extensibility](https://agentclientprotocol.com/protocol/extensibility)
    meta: option<list<tuple<string, string>>>,
  }
  /// An option presented to the user when requesting permission.
  record permission-option {
    /// The _meta property is reserved by ACP to allow clients and agents to attach additional
    /// metadata to their interactions. Implementations MUST NOT make assumptions about values at
    /// these keys.
    ///
    /// See protocol docs: [Extensibility](https://agentclientprotocol.com/protocol/extensibility)
    meta: option<list<tuple<string, string>>>,
    /// Human-readable label to display to the user.
    name: string,
  }
  /// The type of permission option being presented to the user.
  ///
  /// Helps clients choose appropriate icons and UI treatment.
  enum permission-option-kind {
    /// Allow this operation only this time.
    allow-once,
    /// Allow this operation and remember the choice.
    allow-always,
    /// Reject this operation only this time.
    reject-once,
    /// Reject this operation and remember the choice.
    reject-always,
  }
  /// An execution plan for accomplishing complex tasks.
  ///
  /// Plans consist of multiple entries representing individual tasks or goals.
  /// Agents report plans to clients to provide visibility into their execution strategy.
  /// Plans can evolve during execution as the agent discovers new requirements or completes tasks.
  ///
  /// See protocol docs: [Agent Plan](https://agentclientprotocol.com/protocol/agent-plan)
  record plan {
    /// The _meta property is reserved by ACP to allow clients and agents to attach additional
    /// metadata to their interactions. Implementations MUST NOT make assumptions about values at
    /// these keys.
    ///
    /// See protocol docs: [Extensibility](https://agentclientprotocol.com/protocol/extensibility)
    meta: option<list<tuple<string, string>>>,
  }
  /// A single entry in the execution plan.
  ///
  /// Represents a task or goal that the assistant intends to accomplish
  /// as part of fulfilling the user's request.
  /// See protocol docs: [Plan Entries](https://agentclientprotocol.com/protocol/agent-plan#plan-entries)
  record plan-entry {
    /// The _meta property is reserved by ACP to allow clients and agents to attach additional
    /// metadata to their interactions. Implementations MUST NOT make assumptions about values at
    /// these keys.
    ///
    /// See protocol docs: [Extensibility](https://agentclientprotocol.com/protocol/extensibility)
    meta: option<list<tuple<string, string>>>,
    /// Human-readable description of what this task aims to accomplish.
    content: string,
  }
  /// Priority levels for plan entries.
  ///
  /// Used to indicate the relative importance or urgency of different
  /// tasks in the execution plan.
  /// See protocol docs: [Plan Entries](https://agentclientprotocol.com/protocol/agent-plan#plan-entries)
  enum plan-entry-priority {
    /// High priority task - critical to the overall goal.
    high,
    /// Medium priority task - important but not critical.
    medium,
    /// Low priority task - nice to have but not essential.
    low,
  }
  /// Status of a plan entry in the execution flow.
  ///
  /// Tracks the lifecycle of each task from planning through completion.
  /// See protocol docs: [Plan Entries](https://agentclientprotocol.com/protocol/agent-plan#plan-entries)
  enum plan-entry-status {
    /// The task has not started yet.
    pending,
    /// The task is currently being worked on.
    in-progress,
    /// The task has been successfully completed.
    completed,
  }
  /// Prompt capabilities supported by the agent in `session/prompt` requests.
  ///
  /// Baseline agent functionality requires support for [`ContentBlock::Text`]
  /// and [`ContentBlock::ResourceLink`] in prompt requests.
  ///
  /// Other variants must be explicitly opted in to.
  /// Capabilities for different types of content in prompt requests.
  ///
  /// Indicates which content types beyond the baseline (text and resource links)
  /// the agent can process.
  ///
  /// See protocol docs: [Prompt Capabilities](https://agentclientprotocol.com/protocol/initialization#prompt-capabilities)
  record prompt-capabilities {
    /// The _meta property is reserved by ACP to allow clients and agents to attach additional
    /// metadata to their interactions. Implementations MUST NOT make assumptions about values at
    /// these keys.
    ///
    /// See protocol docs: [Extensibility](https://agentclientprotocol.com/protocol/extensibility)
    meta: option<list<tuple<string, string>>>,
    /// Agent supports [`ContentBlock::Audio`].
    audio: bool,
    /// Agent supports embedded context in `session/prompt` requests.
    ///
    /// When enabled, the Client is allowed to include [`ContentBlock::Resource`]
    /// in prompt requests for pieces of context that are referenced in the message.
    embedded-context: bool,
    /// Agent supports [`ContentBlock::Image`].
    image: bool,
  }
  /// Request parameters for sending a user prompt to the agent.
  ///
  /// Contains the user's message and any additional context.
  ///
  /// See protocol docs: [User Message](https://agentclientprotocol.com/protocol/prompt-turn#1-user-message)
  record prompt-request {
    /// The _meta property is reserved by ACP to allow clients and agents to attach additional
    /// metadata to their interactions. Implementations MUST NOT make assumptions about values at
    /// these keys.
    ///
    /// See protocol docs: [Extensibility](https://agentclientprotocol.com/protocol/extensibility)
    meta: option<list<tuple<string, string>>>,
  }
  /// Response from processing a user prompt.
  ///
  /// See protocol docs: [Check for Completion](https://agentclientprotocol.com/protocol/prompt-turn#4-check-for-completion)
  record prompt-response {
    /// The _meta property is reserved by ACP to allow clients and agents to attach additional
    /// metadata to their interactions. Implementations MUST NOT make assumptions about values at
    /// these keys.
    ///
    /// See protocol docs: [Extensibility](https://agentclientprotocol.com/protocol/extensibility)
    meta: option<list<tuple<string, string>>>,
  }
  /// Request to read content from a text file.
  ///
  /// Only available if the client supports the `fs.readTextFile` capability.
  record read-text-file-request {
    /// The _meta property is reserved by ACP to allow clients and agents to attach additional
    /// metadata to their interactions. Implementations MUST NOT make assumptions about values at
    /// these keys.
    ///
    /// See protocol docs: [Extensibility](https://agentclientprotocol.com/protocol/extensibility)
    meta: option<list<tuple<string, string>>>,
    /// Maximum number of lines to read.
    limit: option<s64>,
    /// Line number to start reading from (1-based).
    line: option<s64>,
    /// Absolute path to the file to read.
    path: string,
  }
  /// Response containing the contents of a text file.
  record read-text-file-response {
    /// The _meta property is reserved by ACP to allow clients and agents to attach additional
    /// metadata to their interactions. Implementations MUST NOT make assumptions about values at
    /// these keys.
    ///
    /// See protocol docs: [Extensibility](https://agentclientprotocol.com/protocol/extensibility)
    meta: option<list<tuple<string, string>>>,
    content: string,
  }
  /// Request to release a terminal and free its resources.
  record release-terminal-request {
    /// The _meta property is reserved by ACP to allow clients and agents to attach additional
    /// metadata to their interactions. Implementations MUST NOT make assumptions about values at
    /// these keys.
    ///
    /// See protocol docs: [Extensibility](https://agentclientprotocol.com/protocol/extensibility)
    meta: option<list<tuple<string, string>>>,
    /// The ID of the terminal to release.
    terminal-id: string,
  }
  /// Response to terminal/release method
  record release-terminal-response {
    /// The _meta property is reserved by ACP to allow clients and agents to attach additional
    /// metadata to their interactions. Implementations MUST NOT make assumptions about values at
    /// these keys.
    ///
    /// See protocol docs: [Extensibility](https://agentclientprotocol.com/protocol/extensibility)
    meta: option<list<tuple<string, string>>>,
  }
  /// JSON RPC Request Id
  ///
  /// An identifier established by the Client that MUST contain a String, Number, or NULL value if included. If it is not included it is assumed to be a notification. The value SHOULD normally not be Null [1] and Numbers SHOULD NOT contain fractional parts [2]
  ///
  /// The Server MUST reply with the same value in the Response object if included. This member is used to correlate the context between the two objects.
  ///
  /// [1] The use of Null as a value for the id member in a Request object is discouraged, because this specification uses a value of Null for Responses with an unknown id. Also, because JSON-RPC 1.0 uses an id value of Null for Notifications this could cause confusion in handling.
  ///
  /// [2] Fractional parts may be problematic, since many decimal fractions cannot be represented exactly as binary fractions.
  variant request-id {
    case-zero,
    case-one(s64),
    case-two,
  }
  /// The outcome of a permission request.
  enum request-permission-outcome {
    /// The prompt turn was cancelled before the user responded.
    ///
    /// When a client sends a `session/cancel` notification to cancel an ongoing
    /// prompt turn, it MUST respond to all pending `session/request_permission`
    /// requests with this `Cancelled` outcome.
    ///
    /// See protocol docs: [Cancellation](https://agentclientprotocol.com/protocol/prompt-turn#cancellation)
    case-zero,
    /// The user selected one of the provided options.
    case-one,
  }
  /// Request for user permission to execute a tool call.
  ///
  /// Sent when the agent needs authorization before performing a sensitive operation.
  ///
  /// See protocol docs: [Requesting Permission](https://agentclientprotocol.com/protocol/tool-calls#requesting-permission)
  record request-permission-request {
    /// The _meta property is reserved by ACP to allow clients and agents to attach additional
    /// metadata to their interactions. Implementations MUST NOT make assumptions about values at
    /// these keys.
    ///
    /// See protocol docs: [Extensibility](https://agentclientprotocol.com/protocol/extensibility)
    meta: option<list<tuple<string, string>>>,
  }
  /// Response to a permission request.
  record request-permission-response {
    /// The _meta property is reserved by ACP to allow clients and agents to attach additional
    /// metadata to their interactions. Implementations MUST NOT make assumptions about values at
    /// these keys.
    ///
    /// See protocol docs: [Extensibility](https://agentclientprotocol.com/protocol/extensibility)
    meta: option<list<tuple<string, string>>>,
  }
  /// A resource that the server is capable of reading, included in a prompt or tool call result.
  record resource-link {
    /// The _meta property is reserved by ACP to allow clients and agents to attach additional
    /// metadata to their interactions. Implementations MUST NOT make assumptions about values at
    /// these keys.
    ///
    /// See protocol docs: [Extensibility](https://agentclientprotocol.com/protocol/extensibility)
    meta: option<list<tuple<string, string>>>,
    description: option<string>,
    mime-type: option<string>,
    name: string,
    size: option<s64>,
    title: option<string>,
    uri: string,
  }
  enum role {
    assistant,
    user,
  }
  /// The user selected one of the provided options.
  record selected-permission-outcome {
    /// The _meta property is reserved by ACP to allow clients and agents to attach additional
    /// metadata to their interactions. Implementations MUST NOT make assumptions about values at
    /// these keys.
    ///
    /// See protocol docs: [Extensibility](https://agentclientprotocol.com/protocol/extensibility)
    meta: option<list<tuple<string, string>>>,
  }
  /// Session capabilities supported by the agent.
  ///
  /// As a baseline, all Agents **MUST** support `session/new`, `session/prompt`, `session/cancel`, and `session/update`.
  ///
  /// Optionally, they **MAY** support other session methods and notifications by specifying additional capabilities.
  ///
  /// Note: `session/load` is still handled by the top-level `load_session` capability. This will be unified in future versions of the protocol.
  ///
  /// See protocol docs: [Session Capabilities](https://agentclientprotocol.com/protocol/initialization#session-capabilities)
  record session-capabilities {
    /// The _meta property is reserved by ACP to allow clients and agents to attach additional
    /// metadata to their interactions. Implementations MUST NOT make assumptions about values at
    /// these keys.
    ///
    /// See protocol docs: [Extensibility](https://agentclientprotocol.com/protocol/extensibility)
    meta: option<list<tuple<string, string>>>,
  }
  /// A mode the agent can operate in.
  ///
  /// See protocol docs: [Session Modes](https://agentclientprotocol.com/protocol/session-modes)
  record session-mode {
    /// The _meta property is reserved by ACP to allow clients and agents to attach additional
    /// metadata to their interactions. Implementations MUST NOT make assumptions about values at
    /// these keys.
    ///
    /// See protocol docs: [Extensibility](https://agentclientprotocol.com/protocol/extensibility)
    meta: option<list<tuple<string, string>>>,
    description: option<string>,
    name: string,
  }
  /// The set of modes and the one currently active.
  record session-mode-state {
    /// The _meta property is reserved by ACP to allow clients and agents to attach additional
    /// metadata to their interactions. Implementations MUST NOT make assumptions about values at
    /// these keys.
    ///
    /// See protocol docs: [Extensibility](https://agentclientprotocol.com/protocol/extensibility)
    meta: option<list<tuple<string, string>>>,
  }
  /// Notification containing a session update from the agent.
  ///
  /// Used to stream real-time progress and results during prompt processing.
  ///
  /// See protocol docs: [Agent Reports Output](https://agentclientprotocol.com/protocol/prompt-turn#3-agent-reports-output)
  record session-notification {
    /// The _meta property is reserved by ACP to allow clients and agents to attach additional
    /// metadata to their interactions. Implementations MUST NOT make assumptions about values at
    /// these keys.
    ///
    /// See protocol docs: [Extensibility](https://agentclientprotocol.com/protocol/extensibility)
    meta: option<list<tuple<string, string>>>,
  }
  /// Different types of updates that can be sent during session processing.
  ///
  /// These updates provide real-time feedback about the agent's progress.
  ///
  /// See protocol docs: [Agent Reports Output](https://agentclientprotocol.com/protocol/prompt-turn#3-agent-reports-output)
  enum session-update {
    /// A chunk of the user's message being streamed.
    case-zero,
    /// A chunk of the agent's response being streamed.
    case-one,
    /// A chunk of the agent's internal reasoning being streamed.
    case-two,
    /// Notification that a new tool call has been initiated.
    case-three,
    /// Update on the status or results of a tool call.
    case-four,
    /// The agent's execution plan for complex tasks.
    /// See protocol docs: [Agent Plan](https://agentclientprotocol.com/protocol/agent-plan)
    case-five,
    /// Available commands are ready or have changed
    case-six,
    /// The current mode of the session has changed
    ///
    /// See protocol docs: [Session Modes](https://agentclientprotocol.com/protocol/session-modes)
    case-seven,
  }
  /// Request parameters for setting a session mode.
  record set-session-mode-request {
    /// The _meta property is reserved by ACP to allow clients and agents to attach additional
    /// metadata to their interactions. Implementations MUST NOT make assumptions about values at
    /// these keys.
    ///
    /// See protocol docs: [Extensibility](https://agentclientprotocol.com/protocol/extensibility)
    meta: option<list<tuple<string, string>>>,
  }
  /// Response to `session/set_mode` method.
  record set-session-mode-response {
    meta: option<list<tuple<string, string>>>,
  }
  /// Reasons why an agent stops processing a prompt turn.
  ///
  /// See protocol docs: [Stop Reasons](https://agentclientprotocol.com/protocol/prompt-turn#stop-reasons)
  enum stop-reason {
    /// The turn ended successfully.
    end-turn,
    /// The turn ended because the agent reached the maximum number of tokens.
    max-tokens,
    /// The turn ended because the agent reached the maximum number of allowed
    /// agent requests between user turns.
    max-turn-requests,
    /// The turn ended because the agent refused to continue. The user prompt
    /// and everything that comes after it won't be included in the next
    /// prompt, so this should be reflected in the UI.
    refusal,
    /// The turn was cancelled by the client via `session/cancel`.
    ///
    /// This stop reason MUST be returned when the client sends a `session/cancel`
    /// notification, even if the cancellation causes exceptions in underlying operations.
    /// Agents should catch these exceptions and return this semantically meaningful
    /// response to confirm successful cancellation.
    cancelled,
  }
  /// Embed a terminal created with `terminal/create` by its id.
  ///
  /// The terminal must be added before calling `terminal/release`.
  ///
  /// See protocol docs: [Terminal](https://agentclientprotocol.com/protocol/terminals)
  record terminal {
    /// The _meta property is reserved by ACP to allow clients and agents to attach additional
    /// metadata to their interactions. Implementations MUST NOT make assumptions about values at
    /// these keys.
    ///
    /// See protocol docs: [Extensibility](https://agentclientprotocol.com/protocol/extensibility)
    meta: option<list<tuple<string, string>>>,
    terminal-id: string,
  }
  /// Exit status of a terminal command.
  record terminal-exit-status {
    /// The _meta property is reserved by ACP to allow clients and agents to attach additional
    /// metadata to their interactions. Implementations MUST NOT make assumptions about values at
    /// these keys.
    ///
    /// See protocol docs: [Extensibility](https://agentclientprotocol.com/protocol/extensibility)
    meta: option<list<tuple<string, string>>>,
    /// The process exit code (may be null if terminated by signal).
    exit-code: option<s64>,
    /// The signal that terminated the process (may be null if exited normally).
    signal: option<string>,
  }
  /// Request to get the current output and status of a terminal.
  record terminal-output-request {
    /// The _meta property is reserved by ACP to allow clients and agents to attach additional
    /// metadata to their interactions. Implementations MUST NOT make assumptions about values at
    /// these keys.
    ///
    /// See protocol docs: [Extensibility](https://agentclientprotocol.com/protocol/extensibility)
    meta: option<list<tuple<string, string>>>,
    /// The ID of the terminal to get output from.
    terminal-id: string,
  }
  /// Response containing the terminal output and exit status.
  record terminal-output-response {
    /// The _meta property is reserved by ACP to allow clients and agents to attach additional
    /// metadata to their interactions. Implementations MUST NOT make assumptions about values at
    /// these keys.
    ///
    /// See protocol docs: [Extensibility](https://agentclientprotocol.com/protocol/extensibility)
    meta: option<list<tuple<string, string>>>,
    /// The terminal output captured so far.
    output: string,
    /// Whether the output was truncated due to byte limits.
    truncated: bool,
  }
  /// Text provided to or from an LLM.
  record text-content {
    /// The _meta property is reserved by ACP to allow clients and agents to attach additional
    /// metadata to their interactions. Implementations MUST NOT make assumptions about values at
    /// these keys.
    ///
    /// See protocol docs: [Extensibility](https://agentclientprotocol.com/protocol/extensibility)
    meta: option<list<tuple<string, string>>>,
    text: string,
  }
  /// Text-based resource contents.
  record text-resource-contents {
    /// The _meta property is reserved by ACP to allow clients and agents to attach additional
    /// metadata to their interactions. Implementations MUST NOT make assumptions about values at
    /// these keys.
    ///
    /// See protocol docs: [Extensibility](https://agentclientprotocol.com/protocol/extensibility)
    meta: option<list<tuple<string, string>>>,
    mime-type: option<string>,
    text: string,
    uri: string,
  }
  /// Represents a tool call that the language model has requested.
  ///
  /// Tool calls are actions that the agent executes on behalf of the language model,
  /// such as reading files, executing code, or fetching data from external sources.
  ///
  /// See protocol docs: [Tool Calls](https://agentclientprotocol.com/protocol/tool-calls)
  record tool-call {
    /// The _meta property is reserved by ACP to allow clients and agents to attach additional
    /// metadata to their interactions. Implementations MUST NOT make assumptions about values at
    /// these keys.
    ///
    /// See protocol docs: [Extensibility](https://agentclientprotocol.com/protocol/extensibility)
    meta: option<list<tuple<string, string>>>,
    /// Human-readable title describing what the tool is doing.
    title: string,
  }
  /// Content produced by a tool call.
  ///
  /// Tool calls can produce different types of content including
  /// standard content blocks (text, images) or file diffs.
  ///
  /// See protocol docs: [Content](https://agentclientprotocol.com/protocol/tool-calls#content)
  enum tool-call-content {
    /// Standard content block (text, images, resources).
    case-zero,
    /// File modification shown as a diff.
    case-one,
    /// Embed a terminal created with `terminal/create` by its id.
    ///
    /// The terminal must be added before calling `terminal/release`.
    ///
    /// See protocol docs: [Terminal](https://agentclientprotocol.com/protocol/terminals)
    case-two,
  }
  /// A file location being accessed or modified by a tool.
  ///
  /// Enables clients to implement "follow-along" features that track
  /// which files the agent is working with in real-time.
  ///
  /// See protocol docs: [Following the Agent](https://agentclientprotocol.com/protocol/tool-calls#following-the-agent)
  record tool-call-location {
    /// The _meta property is reserved by ACP to allow clients and agents to attach additional
    /// metadata to their interactions. Implementations MUST NOT make assumptions about values at
    /// these keys.
    ///
    /// See protocol docs: [Extensibility](https://agentclientprotocol.com/protocol/extensibility)
    meta: option<list<tuple<string, string>>>,
    /// Optional line number within the file.
    line: option<s64>,
    /// The file path being accessed or modified.
    path: string,
  }
  /// Execution status of a tool call.
  ///
  /// Tool calls progress through different statuses during their lifecycle.
  ///
  /// See protocol docs: [Status](https://agentclientprotocol.com/protocol/tool-calls#status)
  enum tool-call-status {
    /// The tool call hasn't started running yet because the input is either
    /// streaming or we're awaiting approval.
    pending,
    /// The tool call is currently running.
    in-progress,
    /// The tool call completed successfully.
    completed,
    /// The tool call failed with an error.
    failed,
  }
  /// An update to an existing tool call.
  ///
  /// Used to report progress and results as tools execute. All fields except
  /// the tool call ID are optional - only changed fields need to be included.
  ///
  /// See protocol docs: [Updating](https://agentclientprotocol.com/protocol/tool-calls#updating)
  record tool-call-update {
    /// The _meta property is reserved by ACP to allow clients and agents to attach additional
    /// metadata to their interactions. Implementations MUST NOT make assumptions about values at
    /// these keys.
    ///
    /// See protocol docs: [Extensibility](https://agentclientprotocol.com/protocol/extensibility)
    meta: option<list<tuple<string, string>>>,
    /// Replace the content collection.
    content: option<list<tool-call-content>>,
    /// Replace the locations collection.
    locations: option<list<tool-call-location>>,
    /// Update the human-readable title.
    title: option<string>,
  }
  /// Categories of tools that can be invoked.
  ///
  /// Tool kinds help clients choose appropriate icons and optimize how they
  /// display tool execution progress.
  ///
  /// See protocol docs: [Creating](https://agentclientprotocol.com/protocol/tool-calls#creating)
  enum tool-kind {
    /// Reading files or data.
    read,
    /// Modifying files or content.
    edit,
    /// Removing files or data.
    delete,
    /// Moving or renaming files.
    move,
    /// Searching for information.
    search,
    /// Running commands or code.
    execute,
    /// Internal reasoning or planning.
    think,
    /// Retrieving external data.
    fetch,
    /// Switching the current session mode.
    switch-mode,
    /// Other tool types (default).
    other,
  }
  /// All text that was typed after the command name is provided as input.
  record unstructured-command-input {
    /// The _meta property is reserved by ACP to allow clients and agents to attach additional
    /// metadata to their interactions. Implementations MUST NOT make assumptions about values at
    /// these keys.
    ///
    /// See protocol docs: [Extensibility](https://agentclientprotocol.com/protocol/extensibility)
    meta: option<list<tuple<string, string>>>,
    /// A hint to display when the input hasn't been provided yet
    hint: string,
  }
  /// Request to wait for a terminal command to exit.
  record wait-for-terminal-exit-request {
    /// The _meta property is reserved by ACP to allow clients and agents to attach additional
    /// metadata to their interactions. Implementations MUST NOT make assumptions about values at
    /// these keys.
    ///
    /// See protocol docs: [Extensibility](https://agentclientprotocol.com/protocol/extensibility)
    meta: option<list<tuple<string, string>>>,
    /// The ID of the terminal to wait for.
    terminal-id: string,
  }
  /// Response containing the exit status of a terminal command.
  record wait-for-terminal-exit-response {
    /// The _meta property is reserved by ACP to allow clients and agents to attach additional
    /// metadata to their interactions. Implementations MUST NOT make assumptions about values at
    /// these keys.
    ///
    /// See protocol docs: [Extensibility](https://agentclientprotocol.com/protocol/extensibility)
    meta: option<list<tuple<string, string>>>,
    /// The process exit code (may be null if terminated by signal).
    exit-code: option<s64>,
    /// The signal that terminated the process (may be null if exited normally).
    signal: option<string>,
  }
  /// Request to write content to a text file.
  ///
  /// Only available if the client supports the `fs.writeTextFile` capability.
  record write-text-file-request {
    /// The _meta property is reserved by ACP to allow clients and agents to attach additional
    /// metadata to their interactions. Implementations MUST NOT make assumptions about values at
    /// these keys.
    ///
    /// See protocol docs: [Extensibility](https://agentclientprotocol.com/protocol/extensibility)
    meta: option<list<tuple<string, string>>>,
    /// The text content to write to the file.
    content: string,
    /// Absolute path to the file to write.
    path: string,
  }
  /// Response to `fs/write_text_file`
  record write-text-file-response {
    /// The _meta property is reserved by ACP to allow clients and agents to attach additional
    /// metadata to their interactions. Implementations MUST NOT make assumptions about values at
    /// these keys.
    ///
    /// See protocol docs: [Extensibility](https://agentclientprotocol.com/protocol/extensibility)
    meta: option<list<tuple<string, string>>>,
  }
}
