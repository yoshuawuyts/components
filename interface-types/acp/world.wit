package yoshuawuyts:acp@2.0.3;

/// An ACP agent component: exports [`agent`] (driven by the host) and imports
/// [`client`] (for fs, terminal, and permission callbacks).
///
/// A terminal endpoint in an ACP topology. The host needs no separate world —
/// it provides the `client` import and calls the `agent` export.
world provider {
    export agent;
    import client;
}

/// An ACP layer component: wraps a downstream [`provider`] (or another
/// [`layer`]) with the same protocol on both sides. Exports [`agent`]
/// upstream, imports [`agent`] downstream, and inherits the [`client`]
/// import from [`provider`].
///
/// Useful for logging, prompt rewriting, tool-call filtering, or routing
/// across backends. Analogous to a `tower::Layer`.
world layer {
    include provider;
    import agent;
}
